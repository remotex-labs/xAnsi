{
    "name": "@remotex-labs/xansi",
    "main": "dist/cjs/index.js",
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "./dist/esm/index.js",
    "author": "Garefild",
    "version": "1.0.0-local",
    "license": "Mozilla Public License Version 2.0",
    "homepage": "https://remotex-labs.github.io/xAnsi",
    "description": "A lightweight ANSI utility library for styling terminal output",
    "sideEffects": false,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/remotex-labs/xAnsi.git"
    },
    "bugs": {
        "url": "https://github.com/remotex-labs/xAnsi/issues"
    },
    "keywords": [
        "cli",
        "nasi",
        "xansi",
        "color",
        "shadow",
        "colors",
        "terminal",
        "formatting",
        "ansi-colors",
        "terminal-ui",
        "escape-codes"
    ],
    "engines": {
        "node": ">=20"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        },
        "./ansi.component": {
            "types": "./dist/ansi.component.d.ts",
            "import": "./dist/esm/ansi.component.js",
            "require": "./dist/cjs/ansi.component.js"
        },
        "./xterm.component": {
            "types": "./dist/xterm.component.d.ts",
            "import": "./dist/esm/xterm.component.js",
            "require": "./dist/cjs/xterm.component.js"
        },
        "./shadow.service": {
            "types": "./dist/shadow.service.d.ts",
            "import": "./dist/esm/shadow.service.js",
            "require": "./dist/cjs/shadow.service.js"
        }
    },
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "scripts": {
        "dev":              "xBuild -w",
        "build":            "xBuild",
        "build:clean":      "rm -rf ./dist && xBuild",

        "test":             "xjet",
        "test:coverage":    "xjet --coverage",

        "lint":             "pnpm lint:md && pnpm lint:eslint && pnpm lint:typescript",
        "lint:md":          "markdownlint \"**/*.md\" --ignore node_modules",
        "lint:eslint":      "eslint . -c ./eslint.config.mjs",
        "lint:typescript":  "xBuild --tc",

        "docs:dev":         "vitepress dev docs",
        "docs:build":       "vitepress build docs",
        "docs:preview":     "vitepress preview docs",

        "ci":              "pnpm lint && pnpm test && pnpm build:clean",
        "prepublishOnly":  "pnpm lint && pnpm test && pnpm build:clean"
    },
    "devDependencies": {
        "eslint": "^10.1.0",
        "vitepress": "^2.0.0-alpha.16",
        "markdownlint-cli": "^0.48.0",
        "typescript-eslint": "^8.57.1",
        "eslint-plugin-tsdoc": "^0.5.2",
        "eslint-plugin-perfectionist": "^5.7.0",
        "@types/node": "^25.5.0",
        "@viteplus/versions": "^2.0.6",
        "@remotex-labs/xjet": "^1.5.4",
        "@remotex-labs/xbuild": "^2.2.4"
    }
}
